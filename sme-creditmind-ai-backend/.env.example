# CreditMind AI — FastAPI backend (sme-creditmind-ai-backend)
#
# Setup (pick one):
#   cp .env.example .env
#   cp .env.example .env.local
#
# `app.config.Settings` loads both `.env` and `.env.local` from this folder (if present).
# Values in `.env.local` override `.env`. Use `.env.local` for secrets you do not commit.
# Set at least CREDITMIND_QWEN_API_KEY (or OPENAI) for AI features.
#
# Local run from this folder: `python run.py` or `uvicorn app.main:app --reload`

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# Human-readable service name (OpenAPI title).
CREDITMIND_APP_NAME=CreditMind AI Backend

# SQLAlchemy URL. Default in code is SQLite next to the app: creditmind.db
# Leave empty or omit to use that default (empty string in .env is OK).
# Example Postgres: postgresql+psycopg2://user:pass@localhost:5432/creditmind
CREDITMIND_DATABASE_URL=

# JSON array of allowed browser origins for CORS (Next.js dev server must match).
# Must include the exact URL your frontend uses (scheme + host + port).
CREDITMIND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# -----------------------------------------------------------------------------
# LLM — Qwen (DashScope OpenAI-compatible API) — required for POS / document AI
# -----------------------------------------------------------------------------
# API key: Model Studio console → switch region (e.g. Singapore) → API Key → Create API Key.
# Paste the full key once; you cannot view it again after closing the dialog. Never commit keys.
# Permissions follow the workspace; same key works for compatible-mode models authorized there.
#
# Coding Plan uses dedicated keys (sk-sp-...) and base URLs — this app expects the standard
# Compatible-Mode API (general keys sk-...). See Alibaba docs if you use Coding Plan only.
#
# HTTP 401: wrong key, RAM user deleted, or base URL does not match the region where the key was created.
CREDITMIND_QWEN_API_KEY=

# OpenAI-compatible base URL (no trailing slash). Must match your key’s region (Alibaba Model Studio):
#   Singapore:        https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   US (Virginia):    https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   China (Beijing):  https://dashscope.aliyuncs.com/compatible-mode/v1
#   China (Hong Kong): https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
#   Germany:          https://<WorkspaceId>.eu-central-1.maas.aliyuncs.com/compatible-mode/v1
CREDITMIND_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Vision / multimodal — document & POS images (OCR, layout). Singapore catalog suggestions:
#   Flagship VL:  qwen3.6-plus-2026-04-02   (Qwen3.6-Plus — native vision-language, OCR)
#   Cost / speed: qwen3.6-flash             (Qwen3.6-Flash — cheaper VL)
#   Older VL:     qwen3.5-plus-2026-02-15    (Qwen3.5-Plus)
CREDITMIND_QWEN_MODEL=qwen3.6-plus-2026-04-02

# Text-only — cashflow analysis & credit JSON (no image). Singapore catalog suggestions:
#   Strongest: qwen3-max-2026-01-23  (Qwen3-Max — general-purpose flagship)
#   Balanced:  qwen-plus-2025-12-01   (Qwen-Plus)
#   Cheaper:   qwen-flash-2025-07-28 (Qwen-Flash — long context)
CREDITMIND_QWEN_TEXT_MODEL=qwen3-max-2026-01-23

# -----------------------------------------------------------------------------
# LLM — OpenAI (optional fallback when Qwen is not configured)
# -----------------------------------------------------------------------------
CREDITMIND_OPENAI_API_KEY=
CREDITMIND_OPENAI_BASE_URL=https://api.openai.com/v1
CREDITMIND_OPENAI_MODEL=gpt-4o-mini
# Optional OpenAI headers (leave empty if unused).
CREDITMIND_OPENAI_ORG=
CREDITMIND_OPENAI_PROJECT=

# -----------------------------------------------------------------------------
# Timeouts
# -----------------------------------------------------------------------------
# Per HTTP call to the LLM provider (seconds). Vision + multi-step pipeline may need 60–120.
CREDITMIND_LLM_TIMEOUT_SECONDS=90

# -----------------------------------------------------------------------------
# Frontend ↔ Backend (configure the Next.js app separately)
# -----------------------------------------------------------------------------
# In sme-creditmind-ai/.env.local set:
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# so the browser calls this backend. Ensure CREDITMIND_CORS_ORIGINS includes that frontend origin.

# -----------------------------------------------------------------------------
# Vercel (production / preview) — no .env file is uploaded
# -----------------------------------------------------------------------------
# In the Vercel dashboard: Project → Settings → Environment Variables, add the same
# CREDITMIND_* names and values as above (Production / Preview / Development as needed).
# Redeploy after changing variables. The Python serverless handler (`api/index.py`) reads
# the process environment; `.env` files are not used on Vercel unless you inject them via CI.
#
# Same Vercel project also builds Next.js: set NEXT_PUBLIC_API_URL to your deployment URL
# with no trailing slash (e.g. https://your-app.vercel.app) so the browser calls /api on
# the same origin, or leave empty if your app uses relative /api/* URLs only.
#
# SQLite is not suitable for Vercel serverless (ephemeral filesystem). Use a hosted DB and
# set CREDITMIND_DATABASE_URL to Postgres (or similar) for production.
#
# CORS: include your real site origin in CREDITMIND_CORS_ORIGINS, e.g.:
#   ["https://your-app.vercel.app"]
#
# CLI (optional): `vercel env pull .env.local` after linking the project, to sync vars locally.
