# CreditMind AI — Next.js frontend (sme-creditmind-ai)
#
# Copy to `.env.local` (Next.js convention) and adjust:
#   cp .env.example .env.local
#
# Docs: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
#
# Backend env template: ../sme-creditmind-ai-backend/.env.example
# Start API: cd ../sme-creditmind-ai-backend && python run.py

# -----------------------------------------------------------------------------
# API base URL (browser → backend)
# -----------------------------------------------------------------------------
# Local dev: leave EMPTY so requests stay same-origin and next.config.ts rewrites /api/* → FastAPI.
# next.config sets a long proxyTimeout for slow LLM routes. If you still see "socket hang up"
# / ECONNRESET on multi-minute pipelines, point the browser straight at uvicorn instead:
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8012
# (CORS on the backend must include your UI origin — already allowed for localhost / 127.0.0.1.)
#
# Alternative: set the full FastAPI URL (no trailing slash).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8012
#
# Vercel: usually leave empty if /api is routed to Python on the same deployment.
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# Local proxy target (server-side only; not sent to the browser)
# -----------------------------------------------------------------------------
# Used by next.config.ts rewrites when not on Vercel. With npm run dev:win on Windows, FastAPI binds 8012 (CREDITMIND_PORT). If you run `python run.py` manually with no env, use http://127.0.0.1:8008 instead.
BACKEND_INTERNAL_ORIGIN=http://127.0.0.1:8012
